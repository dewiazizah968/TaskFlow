### Sensitive / local-only files ###
# Real config with DB credentials, Google OAuth2 secrets, Brevo SMTP
# credentials, etc. Keep only a sanitized application.properties.example
# in the repo and ignore the real one everywhere it might live.
application.properties
application.yml
application.yaml
application-*.properties
application-*.yml
src/main/resources/application.properties
src/main/resources/application.yml
!application.properties.example
!application.yml.example
!src/main/resources/application.properties.example
!src/main/resources/application.yml.example

# Personal notes, not meant for the repo
note
note.txt
notes.txt

# User-uploaded runtime files (task attachments, profile pictures, etc.)
uploads/
/uploads/